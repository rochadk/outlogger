<Window x:Class="LauncherLogout.WelcomeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Outlogger"
        Height="480" Width="460"
        WindowStartupLocation="CenterOwner"
        Background="#1a1a2e"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Welcome to Outlogger"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#eaeaea"/>
            <TextBlock Text="Here's how to get started"
                       FontSize="13" Foreground="#8892a0"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Steps -->
        <StackPanel Grid.Row="2" Margin="0,0,0,0">

            <Border Background="#16213e" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#e94560" CornerRadius="14" Width="28" Height="28"
                            VerticalAlignment="Top">
                        <TextBlock Text="1" FontSize="13" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Log in to your launchers"
                                   FontSize="14" FontWeight="SemiBold" Foreground="#eaeaea"/>
                        <TextBlock Text="Make sure Steam and Epic Games are running and you're signed into the accounts you want to save as defaults."
                                   FontSize="12" Foreground="#8892a0" TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="#16213e" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#e94560" CornerRadius="14" Width="28" Height="28"
                            VerticalAlignment="Top">
                        <TextBlock Text="2" FontSize="13" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Click &quot;Log Out&quot;"
                                   FontSize="14" FontWeight="SemiBold" Foreground="#eaeaea"/>
                        <TextBlock Text="Outlogger will save your credentials before signing you out. These become your default accounts."
                                   FontSize="12" Foreground="#8892a0" TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="#16213e" CornerRadius="10" Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#e94560" CornerRadius="14" Width="28" Height="28"
                            VerticalAlignment="Top">
                        <TextBlock Text="3" FontSize="13" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Use &quot;Login&quot; to restore anytime"
                                   FontSize="14" FontWeight="SemiBold" Foreground="#eaeaea"/>
                        <TextBlock Text="One click restores your saved credentials and launches the launcher, signed in and ready to go."
                                   FontSize="12" Foreground="#8892a0" TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Button Grid.Row="6" Content="Got it, let's go"
                Background="#e94560" Foreground="White"
                FontSize="14" FontWeight="SemiBold"
                Padding="0,12" BorderThickness="0"
                Cursor="Hand" HorizontalAlignment="Stretch"
                Click="GotIt_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
